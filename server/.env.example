# Twin Switch Escape - サーバー環境変数サンプル
# 使い方: 値をコピーして実際の環境変数に設定する（このファイル自体は読み込まれない）。
#   例 (bash): export $(grep -v '^#' .env.example | xargs)
#   例 (PowerShell): $env:JWT_SECRET = "dev-secret-change-me"

# リッスンポート（未設定なら 8080）
PORT=8080

# JWT 署名鍵（必須）。本番では十分に長いランダム値を使い、リポジトリに含めない（spec §17.1）。
JWT_SECRET=dev-secret-change-me

# アクセストークン有効期限（時間, 未設定なら 24）
JWT_EXPIRY_HOURS=24
