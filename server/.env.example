# Twin Switch Escape - サーバー環境変数サンプル
# 使い方: 値をコピーして実際の環境変数に設定する（このファイル自体は読み込まれない）。
#   例 (bash): export $(grep -v '^#' .env.example | xargs)
#   例 (PowerShell): $env:JWT_SECRET = "dev-secret-change-me"

# リッスンポート（未設定なら 8080）
PORT=8080

# JWT 署名鍵（必須）。本番では十分に長いランダム値を使い、リポジトリに含めない（spec §17.1）。
JWT_SECRET=dev-secret-change-me

# アクセストークン有効期限（時間, 未設定なら 24）
JWT_EXPIRY_HOURS=24

# PostgreSQL 接続文字列（Phase 3）。
#   未設定（空）→ インメモリ動作（Phase 2 互換）
#   設定あり    → PostgreSQL を使用（docker-compose.yml の値と一致させる）
DATABASE_URL=postgres://twin:twin_pass@localhost:5432/twin_switch?sslmode=disable

# --- Phase 4: マッチング ---
# 待機タイムアウト秒（未設定なら 60）
MATCHMAKING_TIMEOUT_SEC=60
# websocketUrl の基底（未設定なら ws://localhost:8080）
WS_BASE_URL=ws://localhost:8080
